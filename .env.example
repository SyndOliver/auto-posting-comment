# ========================================
# Telegram Bot Configuration
# ========================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs allowed to use the bot
TELEGRAM_ADMIN_IDS=123456789,987654321

# ========================================
# Facebook Page 1
# ========================================
FB_PAGE1_ID=your_page1_id
FB_PAGE1_TOKEN=your_page1_long_lived_access_token
FB_PAGE1_NAME=My Page 1

# ========================================
# Facebook Page 2
# ========================================
FB_PAGE2_ID=your_page2_id
FB_PAGE2_TOKEN=your_page2_long_lived_access_token
FB_PAGE2_NAME=My Page 2

# ========================================
# Facebook App (for Resumable Upload)
# ========================================
FB_APP_ID=your_facebook_app_id

# ========================================
# Settings
# ========================================
# Delay (seconds) before commenting on the post
COMMENT_DELAY_SECONDS=10
# Directory to store downloaded videos temporarily
VIDEO_DOWNLOAD_DIR=./downloads
# Path to SKU mapping CSV file
SKU_MAPPING_FILE=./data/sku_mapping.csv
# Facebook Graph API version
FB_API_VERSION=v21.0
